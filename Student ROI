<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Student ROI Tracker – by Pushpendra</title>

<!-- Chart.js from allowed CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<!-- ════════════════════════════════════════════════════════════
  FIREBASE (works only when hosted – uses gstatic official CDN)
  Replace config values below with YOUR real Firebase project.
  If config is not set, app runs 100% on localStorage safely.
════════════════════════════════════════════════════════════ -->
<script type="module">
import { initializeApp }   from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getFirestore, doc, setDoc, getDoc }
  from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

/* ── PASTE YOUR FIREBASE CONFIG HERE ── */
const FB = {
  apiKey:            "YOUR_API_KEY",
  authDomain:        "YOUR_PROJECT.firebaseapp.com",
  projectId:         "YOUR_PROJECT_ID",
  storageBucket:     "YOUR_PROJECT.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId:             "YOUR_APP_ID"
};

try {
  const app = initializeApp(FB);
  const db  = getFirestore(app);
  window.fbSave = async (uid, data) => {
    try { await setDoc(doc(db,"students",uid), data, {merge:true}); return true; }
    catch(e){ return false; }
  };
  window.fbLoad = async (uid) => {
    try { const s = await getDoc(doc(db,"students",uid)); return s.exists()?s.data():null; }
    catch(e){ return null; }
  };
} catch(e) {
  /* Firebase not configured → silent fallback to localStorage */
  window.fbSave = async () => false;
  window.fbLoad = async () => null;
}
</script>

<style>
/* ════════════════════════════════════════════════════════════
   DESIGN TOKENS – change once, applies everywhere
════════════════════════════════════════════════════════════ */
:root {
  --a:    #6c63ff;     /* accent */
  --a2:   #48cfad;     /* accent 2 */
  --ar:   108,99,255;  /* accent RGB (for rgba) */
  --ok:   #1dd1a1;
  --warn: #feca57;
  --err:  #ff6b6b;
  --bg:   #f0f2f8;
  --sur:  #ffffff;
  --sur2: #f7f8fc;
  --sur3: #eef0f7;
  --txt:  #1e2235;
  --mut:  #8892b0;
  --fnt:  #b8c0d8;
  --bdr:  rgba(0,0,0,0.07);
  --rad:  14px;
  --rads: 8px;
  --shd:  0 4px 24px rgba(108,99,255,0.08);
  --shds: 0 2px 10px rgba(0,0,0,0.06);
  --t:    0.2s ease;
  --hh:   58px;  /* header height */
  --nh:   44px;  /* nav height */
}

/* Dark mode (toggled via class on body) */
body.dark {
  --bg:   #0d0f1a;
  --sur:  #151825;
  --sur2: #1c2033;
  --sur3: #222640;
  --txt:  #e8ecff;
  --mut:  #6272a4;
  --fnt:  #3a4060;
  --bdr:  rgba(255,255,255,0.06);
  --shd:  0 4px 24px rgba(0,0,0,0.35);
  --shds: 0 2px 10px rgba(0,0,0,0.25);
}

/* Exam-based colour themes */
body.t-neet  { --a:#00b894; --a2:#55efc4; --ar:0,184,148; }
body.t-jee   { --a:#0984e3; --a2:#74b9ff; --ar:9,132,227; }
body.t-cuet  { --a:#e17055; --a2:#fab1a0; --ar:225,112,85; }
body.t-ssc   { --a:#d63031; --a2:#ff7675; --ar:214,48,49; }
body.t-other { --a:#6c63ff; --a2:#a29bfe; --ar:108,99,255; }

/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Segoe UI',system-ui,-apple-system,sans-serif;
  background:var(--bg);color:var(--txt);min-height:100vh;
  transition:background var(--t),color var(--t);
  line-height:1.6;-webkit-font-smoothing:antialiased;
}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-thumb{background:var(--a);border-radius:99px}

/* ── WATERMARK (fixed, centred, low opacity, hidden on mobile) ── */
#wm{
  position:fixed;top:50%;left:50%;
  transform:translate(-50%,-50%);
  pointer-events:none;z-index:0;
  opacity:0.06;
  font-size:clamp(60px,10vw,110px);
  font-weight:900;color:var(--a);
  white-space:nowrap;user-select:none;
  letter-spacing:-3px;
}
@media(max-width:600px){#wm{display:none}}

/* ── HEADER ── */
#hdr{
  background:var(--sur);border-bottom:1px solid var(--bdr);
  padding:0 20px;height:var(--hh);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:300;box-shadow:var(--shds);
}
.brand{display:flex;align-items:center;gap:10px}
.brand-dot{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,var(--a),var(--a2));
  display:grid;place-items:center;color:#fff;font-size:17px;
  box-shadow:0 4px 12px rgba(var(--ar),0.35);flex-shrink:0;
}
.brand-t h1{font-size:15px;font-weight:700;letter-spacing:-.3px}
.brand-t p {font-size:11px;color:var(--mut)}
.hdr-r{display:flex;align-items:center;gap:8px}
.sync{
  font-size:11px;padding:3px 9px;border-radius:20px;
  background:var(--sur2);color:var(--mut);
  display:flex;align-items:center;gap:4px;
  border:1px solid var(--bdr);
}
.sync-dot{width:6px;height:6px;border-radius:50%;background:#aaa;transition:background var(--t)}
.sync.ok .sync-dot{background:var(--ok)}
.ibtn{
  width:34px;height:34px;border-radius:9px;
  border:1px solid var(--bdr);background:var(--sur2);
  cursor:pointer;display:grid;place-items:center;
  color:var(--mut);font-size:15px;
  transition:background var(--t),color var(--t),border-color var(--t);
}
.ibtn:hover{background:var(--a);color:#fff;border-color:var(--a)}

/* ── NAV ── */
#nav{
  background:var(--sur);border-bottom:1px solid var(--bdr);
  display:flex;overflow-x:auto;scrollbar-width:none;
  padding:0 10px;position:sticky;top:var(--hh);z-index:290;
  box-shadow:0 2px 8px rgba(0,0,0,0.04);
}
#nav::-webkit-scrollbar{display:none}
.nb{
  padding:11px 14px;border:none;border-bottom:2px solid transparent;
  background:none;color:var(--mut);font-size:12px;font-weight:500;
  cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;
  transition:color var(--t),border-color var(--t);flex-shrink:0;
}
.nb.active{color:var(--a);border-bottom-color:var(--a)}
.nb:hover:not(.active){color:var(--txt)}

/* ── MAIN ── */
main{
  max-width:920px;margin:0 auto;
  padding:20px 14px 80px;
  position:relative;z-index:1;
}
.page{display:none;animation:fu .25s ease}
.page.active{display:block}
@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* ── CARDS ── */
.card{
  background:var(--sur);border-radius:var(--rad);
  padding:18px 20px;border:1px solid var(--bdr);
  box-shadow:var(--shd);margin-bottom:14px;
  transition:box-shadow var(--t);
}
.card:hover{box-shadow:0 6px 28px rgba(var(--ar),0.1)}
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px}
.ch h2{font-size:14px;font-weight:700;display:flex;align-items:center;gap:7px}
.ci{
  width:26px;height:26px;border-radius:7px;
  background:rgba(var(--ar),0.12);color:var(--a);
  display:grid;place-items:center;font-size:13px;flex-shrink:0;
}

/* ── STAT GRID ── */
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:11px;margin-bottom:14px}
.sc{
  background:var(--sur);border:1px solid var(--bdr);
  border-radius:var(--rad);padding:15px;
  position:relative;overflow:hidden;
  transition:transform var(--t),box-shadow var(--t);
}
.sc::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--a),var(--a2));
}
.sc:hover{transform:translateY(-2px);box-shadow:var(--shd)}
.si{font-size:17px;width:32px;height:32px;border-radius:8px;background:rgba(var(--ar),0.1);display:grid;place-items:center;margin-bottom:9px}
.sv{font-size:23px;font-weight:800;color:var(--a);letter-spacing:-.5px;line-height:1}
.sl{font-size:11px;color:var(--mut);margin-top:5px;font-weight:500}

/* ── QUOTE ── */
.qcard{
  background:linear-gradient(135deg,var(--a),var(--a2));
  border-radius:var(--rad);padding:18px 22px;color:#fff;
  margin-bottom:14px;position:relative;overflow:hidden;
}
.qcard::after{content:"\201C";position:absolute;right:16px;top:-6px;font-size:85px;opacity:.14;font-family:serif;line-height:1;pointer-events:none}
.qday{font-size:11px;opacity:.75;background:rgba(255,255,255,.18);padding:2px 10px;border-radius:20px;display:inline-block;margin-bottom:9px}
.qt{font-size:14px;font-style:italic;line-height:1.7;font-weight:500}
.qa{font-size:11.5px;opacity:.8;margin-top:7px}

/* ── COUNTDOWN ── */
.cdc{border-radius:var(--rad);padding:16px 20px;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;border:1px solid}
.cdc.far   {background:rgba(0,184,148,.07);  border-color:rgba(0,184,148,.3)}
.cdc.med   {background:rgba(254,202,87,.09); border-color:rgba(254,202,87,.4)}
.cdc.close {background:rgba(255,107,107,.07);border-color:rgba(255,107,107,.3)}
.cdl h3{font-size:15px;font-weight:700}
.cdl p {font-size:11.5px;color:var(--mut);margin-top:2px}
.cdr{display:flex;gap:7px;flex-wrap:wrap}
.cdbox{background:var(--sur);border-radius:9px;padding:7px 10px;text-align:center;min-width:50px;border:1px solid var(--bdr);box-shadow:var(--shds)}
.cdn{font-size:20px;font-weight:800;color:var(--a);line-height:1}
.cdu{font-size:9.5px;color:var(--mut);font-weight:600;margin-top:2px}

/* ── TIMER ── */
.tdsp{
  font-size:clamp(38px,9vw,62px);font-weight:800;text-align:center;
  letter-spacing:3px;color:var(--a);font-family:'Courier New',monospace;
  padding:22px 0;line-height:1;text-shadow:0 0 40px rgba(var(--ar),.18);
}
.tbtns{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;margin-top:6px}
.tsrc{display:flex;gap:10px;align-items:center;justify-content:center;flex-wrap:wrap;margin-bottom:14px}
.running .tdsp{animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.7}}

/* ── PROGRESS ── */
.pw{margin-top:8px}
.pm{display:flex;justify-content:space-between;font-size:11.5px;color:var(--mut);margin-bottom:5px}
.pb{height:7px;background:var(--sur3);border-radius:99px;overflow:hidden}
.pf{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--a),var(--a2));transition:width .6s ease}

/* ── FORMS ── */
.f{margin-bottom:12px}
.f label{display:block;font-size:11px;font-weight:600;color:var(--mut);margin-bottom:5px;letter-spacing:.4px;text-transform:uppercase}
input,select,textarea{
  width:100%;padding:9px 12px;border:1.5px solid var(--bdr);border-radius:9px;
  font-size:13.5px;background:var(--sur2);color:var(--txt);outline:none;
  font-family:inherit;transition:border-color var(--t),box-shadow var(--t);
}
input:focus,select:focus,textarea:focus{border-color:var(--a);box-shadow:0 0 0 3px rgba(var(--ar),.12)}
textarea{resize:vertical;min-height:76px;line-height:1.6}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px}
@media(max-width:500px){.g2,.g3{grid-template-columns:1fr}}

/* ── BUTTONS ── */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:9px 18px;border-radius:9px;border:none;
  font-size:13px;font-weight:600;cursor:pointer;
  transition:transform .1s,opacity var(--t);letter-spacing:.15px;font-family:inherit;
}
.btn:active{transform:scale(.97)}
.btn-p{background:var(--a);color:#fff;box-shadow:0 4px 14px rgba(var(--ar),.32)}
.btn-p:hover{opacity:.88}
.btn-g{background:var(--ok);color:#fff;box-shadow:0 4px 14px rgba(29,209,161,.28)}
.btn-g:hover{opacity:.88}
.btn-d{background:var(--err);color:#fff;box-shadow:0 4px 14px rgba(255,107,107,.28)}
.btn-d:hover{opacity:.88}
.btn-w{background:var(--warn);color:#7a5800}
.btn-w:hover{opacity:.88}
.btn-o{background:transparent;color:var(--a);border:1.5px solid var(--a)}
.btn-o:hover{background:rgba(var(--ar),.07)}
.btn-gh{background:var(--sur2);color:var(--mut);border:1px solid var(--bdr)}
.btn-gh:hover{color:var(--txt);background:var(--sur3)}
.btn-sm{padding:6px 13px;font-size:11.5px;border-radius:7px}
.bw{width:100%;justify-content:center}

/* ── BADGES / CHIPS ── */
.badge{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:700;padding:2px 9px;border-radius:20px}
.bg{background:rgba(0,184,148,.12);color:#00875a}
.bb{background:rgba(9,132,227,.12);color:#0055cc}
.bo{background:rgba(254,202,87,.2);color:#92400e}
.br{background:rgba(255,107,107,.12);color:#b91c1c}
.bp{background:rgba(108,99,255,.12);color:#5b21b6}
.chip{display:inline-block;font-size:11px;padding:2px 9px;border-radius:20px;background:var(--sur2);border:1px solid var(--bdr);color:var(--mut);font-weight:600}

/* ── SESSION ITEMS ── */
.si2{display:flex;align-items:center;justify-content:space-between;padding:10px 13px;background:var(--sur2);border-radius:9px;margin-bottom:7px;border:1px solid var(--bdr);animation:fu .2s ease;gap:9px}
.sil{display:flex;align-items:center;gap:9px;flex:1;min-width:0}
.stm{font-size:12.5px;font-weight:700;color:var(--a);white-space:nowrap}
.snt{font-size:13px;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ssb{font-size:11px;color:var(--mut);margin-top:1px}
.dbtn{background:none;border:none;cursor:pointer;color:var(--mut);font-size:13px;padding:4px;border-radius:6px;transition:color var(--t),background var(--t);flex-shrink:0}
.dbtn:hover{color:var(--err);background:rgba(255,107,107,.1)}

/* ── ROUTINE ── */
.rg{display:grid;grid-template-columns:1fr 1fr;gap:11px}
@media(max-width:540px){.rg{grid-template-columns:1fr}}
.rb{background:var(--sur2);border:1.5px solid var(--bdr);border-radius:11px;padding:13px;transition:border-color var(--t)}
.rb:focus-within{border-color:var(--a)}
.rbl{font-size:11.5px;font-weight:700;color:var(--mut);margin-bottom:7px;display:flex;align-items:center;gap:5px}
.rb textarea{border:none;background:transparent;padding:0;font-size:12.5px;min-height:68px;box-shadow:none}
.rb textarea:focus{border:none;box-shadow:none;background:transparent}

/* ── TEST TABLE ── */
.tt2{width:100%;border-collapse:collapse;font-size:13px}
.tt2 th{text-align:left;padding:7px 9px;color:var(--mut);font-weight:600;font-size:11px;border-bottom:1px solid var(--bdr);text-transform:uppercase;letter-spacing:.3px}
.tt2 td{padding:8px 9px;border-bottom:1px solid var(--sur3)}
.tt2 tr:last-child td{border-bottom:none}
.tt2 tr:hover td{background:var(--sur2)}

/* ── CHART WRAPPERS ── */
.cw {position:relative;height:190px;margin-top:9px}
.cwm{position:relative;height:230px;margin-top:9px}
.cwl{position:relative;height:270px;margin-top:9px}

/* ── PLAN OUTPUT ── */
.tth{padding:13px 17px;background:linear-gradient(90deg,var(--a),var(--a2));color:#fff}
.tth h3{font-size:14.5px;font-weight:700}
.tth p {font-size:11.5px;opacity:.85;margin-top:2px}
.ttr{display:flex;align-items:center;justify-content:space-between;padding:11px 17px;background:var(--sur);border-bottom:1px solid var(--bdr);font-size:13px;gap:11px;flex-wrap:wrap}
.ttr:last-child{border-bottom:none}
.ttn{display:flex;align-items:center;gap:7px;font-weight:600;min-width:90px}
.ttbw{flex:1;min-width:50px}
.ttb{height:6px;border-radius:99px}
.tthr{font-size:11.5px;color:var(--mut);white-space:nowrap}

/* ── REVISION ITEMS ── */
.ri2{background:var(--sur2);border:1.5px solid var(--bdr);border-radius:11px;padding:13px;margin-bottom:9px;animation:fu .2s ease}
.ri2.ov{border-color:rgba(255,107,107,.4);background:rgba(255,107,107,.04)}
.ri2 h4{font-size:13px;font-weight:700;margin-bottom:3px}
.ri2 p {font-size:11.5px;color:var(--mut);margin-bottom:9px}
.rtgs{display:flex;gap:5px;flex-wrap:wrap}

/* ── REWARD GRID ── */
.rwg{display:grid;grid-template-columns:repeat(auto-fit,minmax(105px,1fr));gap:9px}
.rwi{background:var(--sur2);border:1.5px solid var(--bdr);border-radius:11px;padding:13px;text-align:center;transition:transform var(--t),border-color var(--t)}
.rwi:hover{transform:translateY(-2px)}
.rwi.ul{border-color:var(--a);background:rgba(var(--ar),.06)}
.rwig{font-size:24px;margin-bottom:5px}
.rwin{font-size:11.5px;font-weight:700}
.rwir{font-size:10.5px;color:var(--mut);margin-top:2px}

/* ── SUBJECT ROW (plan) ── */
.srow{display:flex;gap:7px;align-items:center;margin-bottom:9px;flex-wrap:wrap}
.srow input{flex:1;min-width:90px}
.srow input[type="number"]{max-width:85px;flex:none}
.cdot{width:11px;height:11px;border-radius:50%;flex-shrink:0}

/* ── LOGIN MODAL ── */
#lm{position:fixed;inset:0;background:rgba(10,12,25,.65);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:999}
#lb{background:var(--sur);border-radius:18px;padding:34px 28px;width:360px;max-width:95vw;border:1px solid var(--bdr);box-shadow:0 24px 60px rgba(0,0,0,.28);animation:fu .3s ease}
.lico{font-size:42px;text-align:center;margin-bottom:11px}
.lti{font-size:21px;font-weight:800;text-align:center;margin-bottom:4px}
.lsu{font-size:12.5px;color:var(--mut);text-align:center;margin-bottom:22px}

/* ── REWARD POP ── */
#rp{position:fixed;top:74px;right:16px;background:linear-gradient(135deg,#ffd700,#ff8c00);color:#fff;padding:10px 17px;border-radius:13px;font-size:13px;font-weight:700;box-shadow:0 8px 24px rgba(255,165,0,.4);opacity:0;transform:translateY(-10px);transition:opacity .3s,transform .3s;z-index:9998;pointer-events:none}
#rp.show{opacity:1;transform:translateY(0)}

/* ── TOAST ── */
#toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--txt);color:var(--sur);padding:10px 20px;border-radius:9px;font-size:13px;font-weight:500;opacity:0;transition:opacity .25s,transform .25s;pointer-events:none;z-index:9999;white-space:nowrap;box-shadow:0 6px 24px rgba(0,0,0,.2)}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── MISC ── */
.es{text-align:center;padding:34px 18px;color:var(--mut);font-size:13.5px}
.es-i{font-size:36px;margin-bottom:9px}
.div{border:none;border-top:1px solid var(--bdr);margin:13px 0}
.mu{color:var(--mut);font-size:11.5px}
.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}
.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}
.fb{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:7px}
.fc{display:flex;align-items:center;justify-content:center;gap:8px}
.fw7{font-weight:700}
.fs12{font-size:12px}.fs13{font-size:13px}
.acc{color:var(--a)}
.ok-c{color:var(--ok)}
.err-c{color:var(--err)}
.ibox{background:rgba(var(--ar),.07);border:1px solid rgba(var(--ar),.18);border-radius:9px;padding:11px 15px;font-size:13px}
.wbox{background:rgba(254,202,87,.12);border:1px solid rgba(254,202,87,.4);border-radius:9px;padding:11px 15px;font-size:13px;color:#7a5800}
@media(max-width:560px){
  .card{padding:14px}
  .sv{font-size:20px}
  .tdsp{font-size:36px}
  .ch h2{font-size:13px}
}
</style>
</head>
<body class="t-other">

<!-- ══ WATERMARK (centre, fixed, low opacity) ══ -->
