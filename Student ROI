function saveSession(secs,note,src){
  var td=today(),pts=Math.floor(secs/60);
  S.totalSecs+=secs;S.todaySecs+=secs;S.points+=pts;S.coins+=pts;
  S.dailyLog[td]=(S.dailyLog[td]||0)+secs;
  S.pointsLog[td]=(S.pointsLog[td]||0)+pts;
  var yest=offDay(-1);
  if(S.lastDate!==td){
    S.streak=(S.lastDate===yest||S.lastDate==="")?S.streak+1:1;
    S.bestStreak=Math.max(S.bestStreak,S.streak);
    S.lastDate=td;
  }
  S.sessions.unshift({secs:secs,note:note||src||"Study",src:src||"Other",date:td,ts:Date.now()});
  if(S.sessions.length>100)S.sessions=S.sessions.slice(0,100);
  persist();
}

