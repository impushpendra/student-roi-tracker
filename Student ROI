/* ════════════════════════════════════════════
   17. ROI CALCULATION
════════════════════════════════════════════

   Input  = total study hours
   Output = (questions × 0.5) + (avg mock% × 0.3) + (DPP completion% × 0.2)
   ROI    = min(100, round((Output / (Input × 5)) × 100))

   Productivity = productive_mins / (productive + wasted) × 100
*/
function calcROI(){
  var p=S.prodLog[today()]||{};
  var inputH=(S.totalSecs||0)/3600;
  var avgMk=S.tests.length?S.tests.reduce(function(a,t){return a+(t.acc||0);},0)/S.tests.length:0;
  var dppPct=p.da?Math.round((p.dc||0)/p.da*100):0;
  var out=((p.qs||0)*0.5)+(avgMk*0.3)+(dppPct*0.2);
  return Math.min(100,Math.round((out/Math.max(inputH*5,1))*100));
}

function calcProd(){
  var p=S.prodLog[today()]||{};
  var studyM=(S.todaySecs||0)/60,rdM=p.rd||0,rvM=p.rv||0;
  var prodM=studyM+rdM+rvM;
  var wM=p.wt>=0?p.wt:Math.max(0,24*60-8*60-4*60-prodM);
  var tot=prodM+wM;
  return tot?Math.min(100,Math.round((prodM/tot)*100)):0;
}

function roiCol(v){return v>=70?"var(--ok)":v>=40?"var(--warn)":"var(--err)";}

function renderROIBreak(){
  var el=G("roi-break"); if(!el)return;
  var r=calcROI(),p=calcProd();
  el.innerHTML='<div class="g2"><div class="sc"><div class="si">🎯</div><div class="sv" style="color:'+roiCol(r)+'">'+r+'</div><div class="sl">ROI Score /100</div></div>'
    +'<div class="sc"><div class="si">💡</div><div class="sv" style="color:'+roiCol(p)+'">'+p+'%</div><div class="sl">Productivity</div></div></div>'
    +'<div class="ibox mt8 fs12">ROI = (Questions×0.5 + AvgMock%×0.3 + DPP%×0.2) ÷ (StudyHrs×5) × 100</div>';
}

