function addTest(){
  var m=parseFloat(G("tm").value),tot=parseFloat(G("tt").value)||720;
  var name=(G("tn").value||"").trim()||"Mock Test",date=G("td").value||today();
  if(!m){showToast("Enter marks scored!");return;}
  var acc=Math.round((m/tot)*100);
  S.tests.unshift({marks:m,total:tot,acc:acc,name:name,date:date});
  persist();G("tm").value="";G("tn").value="";
  renderTestList();drawTestChart();renderDash();
  showToast("Test added! Accuracy: "+acc+"%");
}

function renderTestList(){
  var el=G("test-list"); if(!el)return;
  if(!S.tests.length){el.innerHTML='<div class="es"><div class="es-i">📋</div>No tests yet. Add your first mock!</div>';return;}
  el.innerHTML='<table class="tt2"><thead><tr><th>#</th><th>Name</th><th>Score</th><th>Accuracy</th><th>Date</th></tr></thead><tbody>'
    +S.tests.map(function(t,i){
      var c=t.acc>=70?"bg":t.acc>=50?"bo":"br";
      return '<tr><td>'+(i+1)+'</td><td>'+esc(t.name)+'</td><td>'+t.marks+'/'+t.total+'</td><td><span class="badge '+c+'">'+t.acc+'%</span></td><td>'+t.date+'</td></tr>';
    }).join("")+'</tbody></table>';
}

var CI={};
function killChart(k){if(CI[k]){try{CI[k].destroy();}catch(e){}CI[k]=null;}}

function drawTestChart(){
  var cv=G("testChart"); if(!cv)return;
  killChart("test");
  if(!S.tests.length)return;
  var arr=S.tests.slice().reverse().slice(-15);
  CI.test=new Chart(cv,{
    type:"line",
    data:{labels:arr.map(function(t){return t.date;}),datasets:[{label:"Accuracy",data:arr.map(function(t){return t.acc;}),borderColor:"#6c63ff",backgroundColor:"rgba(108,99,255,.1)",tension:.4,fill:true,pointRadius:5,pointBackgroundColor:"#6c63ff"}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{min:0,max:100,ticks:{callback:function(v){return v+"%"},font:{size:11}},grid:{color:"rgba(0,0,0,.04)"}},x:{ticks:{font:{size:10},maxRotation:45},grid:{display:false}}}}
  });
}

